# mobile-agent — Telegram + device automation
# Copy to .env in mobile-agent root, or run: ./tg-relay/setup-telegram.sh --test
# Full guide: docs/TELEGRAM_SETUP.md (中文 / English / 日本語)

# ===== 必填 REQUIRED =====
# 这两项不填，Bot 无法收发消息。其余全部可选（有默认值）。

# @landpage_ipa_addr_bot — 收令(tg-relay) + 发消息(iTerm监控/截图) 共用同一 Bot
TELEGRAM_BOT_TOKEN=
# 你与 @landpage_ipa_addr_bot 的私聊 chat_id（正数）。不要填群 ID（负数）
TELEGRAM_CHAT_ID=

# ===== 核心开关 CORE =====
# 自然语言消息 → 注入终端运行 AI；设 0 则只存 inbox 不注入。
TG_RELAY_ITERM_INJECT=1

# 终端后端：terminal=系统自带 Terminal.app（默认）, iterm=iTerm2。
# 收令守护进程 + ./mob inject/capture/shot 必须使用同一个值，否则会注入/捕获到错误的终端。
TG_TERM_BACKEND=terminal

# ===== 可选 OPTIONAL =====

# ----- 安全 / 白名单 -----
# 允许驱动 Bot 的 chat_id 白名单（逗号分隔）。留空则默认仅允许 TELEGRAM_CHAT_ID（机主）。
# TG_RELAY_ALLOWED_CHAT_IDS=6226809975,123456789
# 安全：白名单与 TELEGRAM_CHAT_ID 都为空时，relay 拒绝启动（fail-closed）。
# 没有"放行所有会话"的开关 —— 本 Bot 会向跑着 bypassPermissions 代理的终端键入命令。
# 通过环境变量提前进入审批模式：每次工具调用都需在 Telegram 点按钮确认（默认关）。
# TG_AGENT_APPROVE=0   # 1/true/yes/on 开启；也可用 ./mob 命令切换

# ----- 终端后端与路由 -----
# 注意：下面所有 TG_ITERM_* 键对 TG_TERM_BACKEND 选中的「任意」后端都生效，
#       包括默认的 Terminal.app —— 不要因为名字里有 ITERM 就以为只适用于 iTerm2。

# 回传 Telegram 的格式: html(默认,手机友好) | markdown | plain | screenshot(发终端截图)
# TG_ITERM_FORMAT=html

# 目标窗口/标签（注入 + 捕获 + 监控共用）
# TG_ITERM_WINDOW=1          # 窗口序号，或 front=最前窗口（默认 1）
# TG_ITERM_TAB=1             # 标签页序号（1 起，默认 1）
# TG_ITERM_SESSION=current   # 分屏序号，或 current=当前 pane（默认 current）
# TG_ITERM_SESSION_ID=       # 稳定标识（iTerm2 session GUID / Terminal.app tty）。
#                            # 设了它就按身份定位，重排或关闭其它标签也不会注错；优先于上面的序号。
# TG_ITERM_ALIASES=fz:1:7,mobile-agent:1:11,texus:1:4   # 别名:窗口:标签
# 下列为旧版别名（deprecated alias），由代码内部传递，通常无需手动设置；新配置请用上面的 TG_ITERM_* ：
# ITERM_TARGET_WINDOW / ITERM_TARGET_TAB / ITERM_TARGET_SESSION / ITERM_TARGET_SESSION_ID

# ----- 注入护栏 / 限流 -----
# 注入护栏：单条消息注入终端的最大字符数（默认 2000，超出截断）
# TG_RELAY_MAX_INJECT_CHARS=2000
# 速率限制：每个 chat 两条消息的最小间隔秒数（默认 1，设 0 关闭）
# TG_RELAY_MIN_INTERVAL_SECS=1
# /model 等会弹"切换模型? 1.Yes 2.No"确认框；延迟 N 秒后补按一次 Enter 接受默认项（默认 1.3）
# TG_MODEL_CONFIRM_DELAY=1.3

# ----- 回传监控 (monitor) -----
# 终端输出回传 Telegram（默认复用上面 TELEGRAM_*，无需另配 Bot）
# 一键启动全部: ./mob up
# TG_ITERM_MONITOR_AFTER=45         # 注入后延迟 N 秒 poll 一次发回 TG
# TG_ITERM_MONITOR_INTERVAL=5
# TG_ITERM_MONITOR_TAIL=400          # 省略=默认 400 行（有界，防止每 5s 重扫整个缓冲、避免陈旧完成标记）；显式 0=全部
# TG_ITERM_LOG_BUFFER=1              # 本地累积日志 inbox/iterm-session.log（默认开）
# TG_ITERM_LOG_MAX_LINES=20000       # 本地日志最多保留行数
# TG_ITERM_MONITOR_STABLE_POLLS=2    # 输出稳定 N 次轮询后再发送（避免流式碎片）
# TG_ITERM_MONITOR_SCREENSHOT_IDLE=60  # 上次发文字后 N 秒无新提取内容 → 发终端截图
# TG_ITERM_MONITOR_CHAT_ID=          # 仅当与 TELEGRAM_CHAT_ID 不同时才设
# TG_ITERM_MONITOR_TEXT_FALLBACK=90  # N 秒仍未发出已完成回复时，强制以文字兜底发送（0/off 关闭）
# TG_ITERM_MONITOR_BOT_TOKEN=        # 仅当监控回传想用与收令「不同」的 Bot 时才设；留空复用 TELEGRAM_BOT_TOKEN

# ----- 截图 -----
# TG_ITERM_SCREENSHOT_APP=iTerm        # 截图目标应用名（Terminal 后端请改为 Terminal）
# TG_ITERM_SCREENSHOT_CAPTION=iTerm    # 截图说明文字（默认随后端为 iTerm / Terminal）
# TG_ITERM_SCREENSHOT_NO_SHADOW=1      # 1=去掉窗口阴影（默认）；0=保留
# TG_ITERM_SCREENSHOT_SIMILARITY=0.95  # 与上张截图相似度高于此阈值则跳过发送（默认 0.95）

# ----- 交互提示兜底 -----
# 交互提示卡住自动兜底：停在选择型提示超过 N 秒无人选择 → 自动按 Enter 选第一项
# TG_ITERM_MONITOR_AUTO_DEFAULT=60   # 秒；0/off/false/no 关闭
# TG_ITERM_AUTO_DEFAULT_CAPTION=⏱ 1 分钟未选择，已默认选择第一项

# ----- 守护进程 -----
# 自定义某个 agent 的启动命令（覆盖内置默认）。值含空格，必须加引号（会被守护进程 source）。
# AGENT_CLAUDE_LAUNCH="claude --permission-mode bypassPermissions --model opus"
# AGENT_CODEX_LAUNCH="codex --model gpt-5"
#
# 守护进程重启退避（可选）：崩溃自动重启，窗口内重启过多则停手，防 crash-loop 刷屏。
# tg-relay（收令）：
# TG_RELAY_RESTART_DELAY=3    # 崩溃后重启间隔秒数（默认 3）
# TG_RELAY_MAX_BURST=10       # 窗口内最大重启次数，达到即停（默认 10）
# TG_RELAY_BURST_WINDOW=60    # 重启计数窗口秒数（默认 60）
# iterm-monitor（回传）：
# TG_MONITOR_RESTART_DELAY=3  # 崩溃后重启间隔秒数（默认 3）
# TG_MONITOR_MAX_BURST=10     # 窗口内最大重启次数，达到即停（默认 10）
# TG_MONITOR_BURST_WINDOW=60  # 重启计数窗口秒数（默认 60）

# ----- iOS -----
# iOS (optional — also in mob-compose/compose.env)
# IOS_DEVELOPMENT_TEAM=
# IOS_UDID=
# IOS_WDA_BUNDLE_ID=
# IOS_WDA_URL=http://127.0.0.1:8100

# ----- Android -----
# Android (optional)
# ADB_SERIAL=
# 远程解锁（/unlock）：数字 PIN 锁的密码。仅数字 PIN 支持，图案/指纹不行。
# 不进 argv（子进程从环境读）。留空则 /unlock 提示未配置。
# ANDROID_UNLOCK_PIN=
