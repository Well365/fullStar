# Copy to devkit.env — do not commit secrets

# Telegram (optional if already in mobile-agent/.env)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# iOS — for one-click WDA xcodebuild (find in Xcode → Accounts → Team ID)
# IOS_DEVELOPMENT_TEAM=ABCDE12345
# IOS_UDID=00008030-...
# IOS_WDA_BUNDLE_ID=com.your.game.bundle
# IOS_WDA_URL=http://127.0.0.1:8100

# Android
# ADB_SERIAL=emulator-5554
